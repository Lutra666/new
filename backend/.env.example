# 服务器配置
NODE_ENV=development
PORT=3001
BIND_HOST=127.0.0.1

# 演示模式
USE_REAL_DB=false
DEFAULT_ADMIN_PASSWORD=admin123
MOCK_DATA_DIR=
DATA_ENCRYPTION_KEY=change-this-data-encryption-key

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=finance_system

# JWT 配置
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d
JWT_ISSUER=finance-system
JWT_AUDIENCE=finance-desktop
BACKUP_SIGN_KEY=change-this-backup-sign-key
SECONDARY_BACKUP_DIR=
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_MINUTES=1440
ALLOW_PUBLIC_REGISTER=false

# 登录安全
ACCOUNT_LOCK_MAX_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# 跨域白名单（生产环境建议配置，多个用逗号分隔）
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# 连接池配置
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=30000
